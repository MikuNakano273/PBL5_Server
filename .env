# =============================================
# PBL5 Server - Environment Variables Example
# Copy this file to .env and fill in values
# =============================================

# --- Server ---
PORT=3000
API_PREFIX=api
NODE_ENV=development
CORS_ORIGINS=http://localhost:3001,http://localhost:8080

# --- MongoDB ---
MONGODB_URI=mongodb://admin:admin123@localhost:27017/pbl5?authSource=admin

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- MinIO ---
MINIO_HOST=localhost
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pbl5-images
MINIO_REGION=us-east-1

# --- JWT ---
JWT_ACCESS_SECRET=change-me-to-a-very-long-random-secret-access
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-a-very-long-random-secret-refresh
JWT_REFRESH_EXPIRES_DAYS=30

# --- Internal Worker Token ---
INTERNAL_WORKER_TOKEN=internal-secret-change-me

# --- Device Config ---
DEVICE_OFFLINE_THRESHOLD_SECONDS=60
DEVICE_HEARTBEAT_INTERVAL_MS=30000
DEVICE_GPS_INTERVAL_MS=5000
DEVICE_TELEMETRY_INTERVAL_MS=500

# --- Alert Thresholds ---
ALERT_DISTANCE_DANGER_CM=100
ALERT_DISTANCE_WARNING_CM=150
ALERT_DEDUP_SECONDS=30

# --- Sampling ---
DISTANCE_SAMPLING_MIN_MS=1500

# --- Telemetry Retention ---
TELEMETRY_RETENTION_DAYS=7
GPS_RETENTION_DAYS=30

# --- Firebase (optional, leave empty to disable push) ---
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- Worker (Python) ---
YOLO_MODEL_PATH=/models/yolov8s.pt
YOLO_CONFIDENCE_THRESHOLD=0.35
INTERNAL_API_URL=http://api:3000
