# =============================================
# PBL5 Server API - FastAPI Environment Example
# Copy this file to .env and fill in values
# =============================================

# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080

# --- MongoDB ---
MONGODB_URI=mongodb://localhost:27017/pbl5
MONGODB_DB_NAME=pbl5

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- MinIO ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pbl5-images
MINIO_USE_SSL=false
MINIO_REGION=us-east-1
IMAGE_UPLOAD_URL_TTL_SECONDS=900

# --- JWT / Internal ---
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRES_MINUTES=15
JWT_REFRESH_EXPIRES_DAYS=30
INTERNAL_WORKER_TOKEN=change-me

# --- Worker ---
YOLO_MODEL_PATH=/models/yolov8s.pt
YOLO_CONFIDENCE_THRESHOLD=0.35
INTERNAL_API_URL=http://localhost:8000
VISION_QUEUE_NAME=vision-jobs
VISION_JOB_TIMEOUT_SECONDS=120
VISION_RETRY_MAX=3
VISION_RETRY_INTERVALS=3,9,27

# --- Alert / Telemetry ---
ALERT_DISTANCE_THRESHOLD_CM=100
ALERT_DEDUP_WINDOW_SECONDS=300
DISTANCE_SAMPLING_MIN_SECONDS=2
DISTANCE_SAMPLING_DELTA_CM=10
GPS_RETENTION_DAYS=60
DISTANCE_RETENTION_DAYS=14
INSTALLATION_NOTIFICATION_RETENTION_DAYS=90
RAW_IMAGE_RETENTION_DAYS=30
